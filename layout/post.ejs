<div class="post-main">
    <% if (is_post()) { %>
        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "Article",
          "headline": "<%= page.title %>",
          "description": "<%= page.description || '' %>",
          "datePublished": "<%= page.date.toISOString() %>",
          "dateModified": "<%= (page.updated ? page.updated.toISOString() : page.date.toISOString()) %>",
          "author": {
            "@type": "Person",
            "name": "<%= page.author || 'drummor' %>"
          },
          "publisher": {
            "@type": "Organization",
            "name": "滑动窗口",
            "url": "https://drummor.github.io"
          },
          "url": "<%= page.permalink %>"
        }
        </script>
        <%
            // 计算阅读时间（去除音频链接后统计）
            var cleanContent = page.content.replace(/\[[^\]]*\]\(\/audio\/[^)]*\.m4a\)/g, '');
        %>
        <div class="post-header-block">
            <div class="post-main-title">
                <%= page.title %>
            </div>
            <div class="post-meta-bar">
                <span class="post-date"><%- date(page.date, "YYYY.MM.DD") %></span>
                <% page.categories.forEach(function(category) { %>
                    <a class="post-category-link" href="<%= url_for(category.path) %>"><%= category.name %></a>
                <% }); %>
            </div>
        </div>
        <% if (page.audio) { %>
        <div class="post-audio-player">
            <div class="podcast-badge">
                <svg class="podcast-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                </svg>
                <span>播客</span>
            </div>
            <audio controls src="<%- url_for(page.audio) %>"></audio>
        </div>
        <% } %>
        <% if (page.description) { %>
        <div class="post-digest">
            <div class="post-digest-label">导读精华</div>
            <div class="post-digest-content"><%- page.description %></div>
        </div>
        <% } %>
        <div class="post-md">
            <%- cleanContent %>
        </div>
    <% } else if(page.title.endsWith('thoughts')) { %>
        <div class="post-md-t">
            <%- page.content %>
        </div>
    <% } else { %>
        <div class="post-md">
            <%- page.content %>
        </div>
    <% } %>
<!-- tags -->
<% if (page.tags && page.tags.length > 0) { %>
    <div class="post-tags">
        <% page.tags.forEach(function(tag) { %>
            <a class="post-tag" href="<%= url_for(tag.path) %>">#<%= tag.name %></a>
        <% }); %>
    </div>
<% } %>
</div>
