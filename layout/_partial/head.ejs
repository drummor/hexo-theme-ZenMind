<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" name="viewport" />
  <meta name="robots" content="index, follow">
  <!-- title -->
  <% if (page.total > 1){ %>
    <% if (page.current === 1) { %>
  <title><%= config.title %> <%= config.subtitle %></title>
    <% } else { %>
  <title>第<%= page.current %>页 - <%= config.title %></title>
    <% } %>
  <% } else { %>
    <% if (is_archive()) { %>
  <title>所有文章 - <%= config.title %></title>
    <% } else if (is_category()) { %>
  <title><%= page.category %> - <%= config.title %></title>
    <% } else if (is_tag()) { %>
  <title><%= page.tag %> - <%= config.title %></title>
    <% } else if (is_post()) { %>
  <title><%= page.title %> - <%= config.title %></title>
    <% } else if (page.path === 'index.html' || page.path === '') { %>
  <title><%= config.title %> - <%= config.subtitle %></title>
    <% } else { %>
  <title><%= page.title %> - <%= config.title %></title>
    <% } %>
  <% } %>

  <meta name="google-site-verification" content="igPREC091ZsMcPyMqt6hg6HDwnFbZXWOPIbU6J0YDKA" />
  
  <!-- Open Graph -->
  <meta property="og:type" content="<%= is_post() ? 'article' : 'website' %>">
  <meta property="og:title" content="<%= is_post() ? page.title + ' - ' + config.title : (config.title + ' - ' + config.subtitle) %>">
  <meta property="og:description" content="<%= is_post() && (page.seo_description || page.description) ? (page.seo_description || page.description) : config.description %>">
  <meta property="og:url" content="<%= config.url + (page.path.startsWith('/') ? '' : '/') + page.path.replace('index.html', '') %>">
  <meta property="og:site_name" content="<%= config.title %>">
  <meta property="og:locale" content="zh_CN">
  <% if (is_post() && page.cover) { %>
  <meta property="og:image" content="<%= page.cover %>">
  <% } else if (!is_post()) { %>
  <meta property="og:image" content="<%= config.url %>/img/og-image.png">
  <% } %>

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= is_post() ? page.title + ' - ' + config.title : config.title + ' - ' + config.subtitle %>">
  <meta name="twitter:description" content="<%= is_post() && (page.seo_description || page.description) ? (page.seo_description || page.description) : config.description %>">
  <% if (is_post() && page.cover) { %>
  <meta name="twitter:image" content="<%= page.cover %>">
  <% } %>
  <!-- meta description -->
  <meta name="description" content="<%= is_post() && (page.seo_description || page.description) ? (page.seo_description || page.description) : config.description %>">
  <!-- canonical -->
  <link rel="canonical" href="<%= config.url + (page.path.startsWith('/') ? '' : '/') + page.path.replace('index.html', '') %>">
  <!-- Favicon -->
  <link rel="shortcut icon" href="/img/favicon.ico">
  <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png">
  <!-- CSS -->
  <%- css('css/reset.css') %>
  <%- css('css/style.css') %>
  <%- css('css/markdown.css') %>
  <%- css('css/markdown_thoughts.css') %>
  <%- css('css/fonts.css') %>
</head>
